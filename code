void handleDELcommand(String input) {
  input.trim();
  if (!input.startsWith("DEL-")) {
        Serial.println(F("ERROR: Malformed DEL command - Missing 'DEL-' prefix"));
        return;
    }
    
    String ID = input.substring(4);

    if (ID.length() != 7 || !isDigits(ID)) {
        Serial.println(F("ERROR: Invalid ID in DEL command (must be 7 digits)"));
        return;
    }
    
    // Search for the matching account
    int deleteIndex = -1;
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].ID == ID) {
            deleteIndex = i;
            break;
        }
    }


    if (deleteIndex == -1) {
        Serial.println(F("ERROR: Employee ID not found"));
        return;
    }

    // Deletes the account by shifting the accounts up
    for (int i = deleteIndex; i < accountCount - 1; i++) {
        accounts[i] = accounts[i + 1];
    }
    accountCount--; 

   
    Serial.println(F("DONE!: Account deleted"));

    if (accountCount > 0) {
      payrollDisplay(currentAccountIndex);
}   else {
      lcd.clear();
      lcd.print(F("No accounts"));
}
   

    Serial.println(F("DONE! Account deleted"));
}

bool isDigits(String str) {
    for (int i = 0; i < str.length(); i++) {
        if (!isDigit(str[i])) return false;
    }
    return true;
}
bool isValidJobTitle(String jobTitle) {
    for (int i = 0; i < jobTitle.length(); i++) {
        char c = jobTitle[i];
        if (!(isAlphaNumeric(c) || c == '.')) return false;
        if (c=='-') return false;
    }
    return true;
}
bool accountExists(String ID) {
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].ID == ID) {
          return true;
        }
    }
    return false;
}
void sortAccountsByID() {
    for (int i = 0; i < accountCount - 1; i++) {
        for (int j = i + 1; j < accountCount; j++) {
            if (accounts[i].ID.toInt() > accounts[j].ID.toInt()) {  // converts ID string to an integer
                payrollAccount temp = accounts[i];
                accounts[i] = accounts[j];  // swaps their positions
                accounts[j] = temp;
            }
        }
    }
}

void payrollDisplay(int accountIndex){
  lcd.clear();

    if (accountIndex < 0 || accountIndex >= accountCount) {
        lcd.print(F("ERROR: No accounts"));
        return;
    }

    payrollAccount account = accounts[accountIndex];
    

    // Set backlight color based on pension status
    if (account.pensionStat == "PEN") {
        lcd.setBacklight(2); // Green
    } else {
        lcd.setBacklight(1); // Red
    }
    lcd.createChar(0, upArrow);
    lcd.createChar(1, downArrow);

    
    lcd.setCursor(0, 0);
    if (accountIndex > 0) lcd.write((uint8_t)0);
    else lcd.print(" ");

   
    lcd.print(account.jobGrade);
    lcd.print(" ");
    lcd.print(account.pensionStat);

    

    
    lcd.setCursor(0, 1);
    if (accountIndex < accountCount - 1) lcd.write((uint8_t)1);
    else lcd.print(" ");
    lcd.print(account.ID);
    lcd.print(" ");
   
    // Stores the current job title for scrolling
    currentJobTitle = account.jobTitle;

    // Displays the job title (first 8 characters initially)
    lcd.setCursor(9, 1);
    if (currentJobTitle.length() > 8) {
        lcd.print(currentJobTitle.substring(0, 8));
    } else {
        lcd.print(currentJobTitle);
    }
    

    lcd.setCursor(8, 0);
    lcd.print(account.salary, 2);
 
    
 
}